---
import { Image } from 'astro:assets';
import { SITE } from 'astrowind:config';
import logo from '~/assets/images/logo.png';
---

<Image
  src={logo}
  alt={`${SITE?.name ?? 'KONVOI'} Logo`}
  class="h-8 w-auto self-center dark:invert"
  loading="eager"
  decoding="async"
  format="avif"
  quality={80}
/>
