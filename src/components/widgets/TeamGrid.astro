---
// src/components/widgets/TeamGrid.astro
// D-08, D-09, D-10 — responsive 2/3/4-col grid of team member cards
// Reads from team content collection (short-form I18N-07 pattern)

import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';

interface Props {
  members: CollectionEntry<'team'>[];
  locale: 'de' | 'en';
}

const { members, locale } = Astro.props;

const teamImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/team/*.png', { eager: true });

// Sort by order field ascending; unordered members go last
const sorted = [...members].sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

function getInitials(name: string): string {
  return name
    .split(' ')
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? '')
    .join('');
}

function resolvePhoto(filename?: string): ImageMetadata | undefined {
  if (!filename) return undefined;
  const key = `/src/assets/images/team/${filename}`;
  return teamImages[key]?.default;
}
---

<div class="grid grid-cols-3 gap-6">
  {sorted.map((member) => {
    const name = locale === 'de' ? member.data.name.de : member.data.name.en;
    const jobTitle = locale === 'de' ? member.data.title.de : member.data.title.en;
    const bio = locale === 'de' ? member.data.bio.de : member.data.bio.en;
    const initials = getInitials(name);
    const photo = resolvePhoto(member.data.photo);

    return (
      <div class="intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade flex flex-col items-center text-center rounded-2xl p-4 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-slate-800/50">
        {/* Photo with initials fallback */}
        <div class="relative mb-4 h-40 w-40 overflow-hidden rounded-xl">
          {photo ? (
            <Image
              src={photo}
              alt={name}
              width={160}
              height={160}
              loading="lazy"
              class="h-full w-full object-cover"
            />
          ) : (
            <div
              class="flex h-full w-full items-center justify-center rounded-xl bg-[hsl(217_60%_93%)] dark:bg-slate-700 text-2xl font-bold font-heading text-slate-600 dark:text-slate-300"
              aria-label={name}
            >
              {initials}
            </div>
          )}
        </div>
        <h3 class="text-xl font-semibold font-heading text-slate-900 dark:text-white leading-snug">
          {name}
        </h3>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400 font-body">
          {jobTitle}
        </p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300 font-body leading-relaxed">
          {bio}
        </p>
      </div>
    );
  })}
</div>
