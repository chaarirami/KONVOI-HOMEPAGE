---
import Button from '~/components/ui/Button.astro';

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  actions?: Array<{ variant: 'primary' | 'secondary'; text: string; href: string; icon?: string }>;
  videoSrc: string;
  posterImage?: string;
  id?: string;
}

const {
  title,
  subtitle,
  tagline,
  actions,
  videoSrc,
  posterImage,
  id,
} = Astro.props;
---

<section class="relative md:-mt-[76px] not-prose overflow-hidden min-h-[70vh] flex items-center" {...id ? { id } : {}}>
  {/* Background video */}
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover -z-10"
    poster={posterImage}
  >
    <source src={videoSrc} type="video/mp4" />
    <track kind="descriptions" src="" label="" />
  </video>

  {/* Dark overlay for text contrast */}
  <div class="absolute inset-0 bg-black/50" style="z-index: -5;"></div>

  {/* Hero content */}
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center w-full">
    {tagline && (
      <p class="text-base text-blue-300 font-bold tracking-wide uppercase mb-4">
        {tagline}
      </p>
    )}
    {title && (
      <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 text-white font-heading">
        {title}
      </h1>
    )}
    {subtitle && (
      <p class="text-xl text-gray-200 mb-8 max-w-3xl mx-auto">
        {subtitle}
      </p>
    )}
    {actions && actions.length > 0 && (
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        {actions.map((action) => (
          <Button variant={action.variant} text={action.text} href={action.href} icon={action.icon} />
        ))}
      </div>
    )}
  </div>
</section>
