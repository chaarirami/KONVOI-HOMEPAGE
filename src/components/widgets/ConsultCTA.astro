---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ConsultForm from '~/components/islands/ConsultForm';
import { t } from '~/i18n/translations';

interface Props {
  locale: 'de' | 'en';
  id?: string;
}

const { locale, id = 'consult' } = Astro.props;
const calUrl = import.meta.env.PUBLIC_CAL_BOOKING_URL;
---

<WidgetWrapper id={id}>
  <div class="mx-auto max-w-xl px-4 sm:px-6">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold font-heading mb-2">
        {t('cta.consult_title', locale)}
      </h2>
      <p class="text-slate-600 dark:text-slate-300">
        {t('cta.consult_subtitle', locale)}
      </p>
    </div>
    <ConsultForm client:load locale={locale} />
    {calUrl && (
      <div class="mt-10 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 text-center">
        <h3 class="text-xl font-bold font-heading mb-2">
          {t('thanks.cal_heading', locale)}
        </h3>
        <p class="text-slate-600 dark:text-slate-400 mb-6">
          {t('thanks.cal_body', locale)}
        </p>
        <a
          href={calUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-lg bg-primary px-6 py-3 text-white font-semibold hover:bg-primary/90 transition-colors"
        >
          {t('thanks.cal_cta', locale)}
        </a>
      </div>
    )}
  </div>
</WidgetWrapper>
