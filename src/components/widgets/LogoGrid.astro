---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

interface LogoEntry {
  name: string;
  href: string;
  logo: ImageMetadata;
}

interface Props {
  title: string;
  logos: LogoEntry[];
  id?: string;
  isDark?: boolean;
}

const { title, logos, id, isDark = false } = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-6xl mx-auto">
  <p class="text-center text-sm font-bold tracking-widest uppercase text-gray-500 dark:text-gray-400 mb-8">
    {title}
  </p>
  <div class="flex flex-wrap justify-center gap-x-10 gap-y-8 items-center">
    {logos.map((entry) => (
      <a
        href={entry.href}
        target="_blank"
        rel="noopener noreferrer"
        class="logo-cell"
      >
        <Image
          src={entry.logo}
          alt={entry.name}
          widths={[150, 250]}
          sizes="120px"
          class="logo-img"
          loading="lazy"
          decoding="async"
        />
      </a>
    ))}
  </div>
</WidgetWrapper>

<style>
  .logo-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 140px;
    height: 60px;
    transition: opacity 0.2s ease;
  }

  .logo-cell:hover {
    opacity: 0.7;
  }

  .logo-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
</style>
