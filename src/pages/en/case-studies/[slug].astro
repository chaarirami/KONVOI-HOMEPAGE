---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export async function getStaticPaths() {
  const entries = await getCollection('caseStudy', (e) => e.data.locale === 'en');
  return entries.map((entry) => ({
    params: { slug: entry.data.canonicalKey },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'caseStudy'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, customer, vertical, problem, approach, outcome, quote, quoteAttribution, logo, coverImage } = entry.data;

const metadata = {
  title: `${customer} — Case Study | KONVOI`,
  description: outcome.slice(0, 155),
};
---

<Layout metadata={metadata}>
  <!-- Quote-first hero — D-02 -->
  <section class="bg-[hsl(217_60%_93%)] dark:bg-slate-800 py-16 px-4">
    <div class="mx-auto max-w-3xl text-center">
      {logo && (
        <img src={logo} alt={`${customer} logo`} class="mx-auto mb-6 h-12 w-auto object-contain" loading="eager" width="160" height="48" />
      )}
      {quote && (
        <blockquote class="mb-4 text-xl italic font-body text-slate-700 dark:text-slate-200 leading-relaxed">
          "{quote}"
        </blockquote>
      )}
      {quoteAttribution && (
        <cite class="text-sm text-slate-500 dark:text-slate-400 not-italic">{quoteAttribution}</cite>
      )}
      <div class="mt-4">
        <span class="inline-block rounded px-2 py-0.5 text-xs font-medium bg-[hsl(217.14_42%_80.39%)] text-slate-900">
          {vertical}
        </span>
      </div>
      <h1 class="mt-6 text-3xl font-bold font-heading text-slate-900 dark:text-white">{title}</h1>
    </div>
  </section>

  <!-- Problem / Approach / Outcome — D-02 -->
  <div class="mx-auto max-w-3xl px-4 py-12 space-y-12">
    <section>
      <h2 class="mb-4 text-2xl font-bold font-heading text-slate-900 dark:text-white">The Problem</h2>
      <p class="text-lg font-body text-slate-700 dark:text-slate-300 leading-relaxed">{problem}</p>
    </section>
    <section>
      <h2 class="mb-4 text-2xl font-bold font-heading text-slate-900 dark:text-white">Our Approach</h2>
      <p class="text-lg font-body text-slate-700 dark:text-slate-300 leading-relaxed">{approach}</p>
    </section>
    <section>
      <h2 class="mb-4 text-2xl font-bold font-heading text-slate-900 dark:text-white">The Outcome</h2>
      <p class="text-lg font-body text-slate-700 dark:text-slate-300 leading-relaxed">{outcome}</p>
    </section>
    <!-- Markdown body (supplementary narrative) -->
    <div class="prose dark:prose-invert max-w-none font-body">
      <Content />
    </div>
  </div>

  <!-- End CTA — CASE-04, D-02 -->
  <CallToAction
    title="Ready for preventive fleet security?"
    subtitle="Book a no-obligation consultation — we will show you exactly how KONVOI protects your fleet."
    actions={[{ variant: 'primary', text: 'Book a consult', href: '/en/contact' }]}
  />
</Layout>
