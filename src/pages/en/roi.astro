---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import RoiCalculator from '~/components/islands/RoiCalculator';
import { t } from '~/i18n/translations';

const locale = 'en' as const;

const metadata = {
  title: 'ROI Calculator — KONVOI Security System',
  description:
    'Calculate your fleet savings with KONVOI — including 80% government funding through the Security & Environment Program.',
};
---

<PageLayout metadata={metadata}>
  <Hero
    tagline={t('roi.page_tagline', locale)}
    title={t('roi.page_title', locale)}
    subtitle={t('roi.page_subtitle', locale)}
  />

  <WidgetWrapper id="roi-calculator">
    <div class="mx-auto max-w-2xl">
      <RoiCalculator client:load locale={locale} embedMode="full" />
    </div>
  </WidgetWrapper>

  <CallToAction
    title="Ready to take the next step?"
    subtitle="Our team will explain how KONVOI protects your fleet in 20 minutes."
    actions={[{ text: t('cta.book_consult', locale), href: '/en/pricing/#consult-form', variant: 'primary' }]}
  />
</PageLayout>
