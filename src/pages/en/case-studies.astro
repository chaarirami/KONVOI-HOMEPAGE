---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import CaseStudyCard from '~/components/widgets/CaseStudyCard.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const entries = await getCollection('caseStudy', (e) => e.data.locale === 'en');
const sorted = entries.sort((a, b) =>
  (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
);

const metadata = {
  title: 'Case Studies — KONVOI GmbH',
  description: 'Learn how companies use KONVOI to prevent cargo theft, diesel theft, and trailer damage before it occurs.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-[hsl(214.48_38.33%_55.49%)]">Customer Stories</p>
      <h1 class="text-4xl font-bold font-heading text-slate-900 dark:text-white">Case Studies</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Real outcomes from companies that chose preventive fleet security.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((entry) => (
        <CaseStudyCard
          canonicalKey={entry.data.canonicalKey}
          customer={entry.data.customer}
          vertical={entry.data.vertical}
          outcome={entry.data.outcome}
          logo={entry.data.logo}
          coverImage={entry.data.coverImage}
          locale="en"
        />
      ))}
    </div>
  </section>
  <CallToAction
    title="Ready for preventive security?"
    subtitle="Book a no-obligation consultation — we will show you exactly how KONVOI protects your fleet."
    actions={[{ variant: 'primary', text: 'Book a consult', href: '/en/contact' }]}
  />
</Layout>
