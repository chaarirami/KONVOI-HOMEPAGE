---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { pricingTiers } from '~/data/pricing';
import { t } from '~/i18n/translations';
import RoiCalculator from '~/components/islands/RoiCalculator';
import ConsultForm from '~/components/islands/ConsultForm';

const locale = 'en' as const;

const metadata = {
  title: 'Pricing — KONVOI Security System',
  description: 'KONVOI pricing for fleet security. Three tiers: Standard, Camera Module, Logbook. Up to 80% government-funded.',
};
---

<PageLayout metadata={metadata}>
  <Hero
    tagline="Pricing"
    title="Invest in fleet security — up to 80% government-funded"
    subtitle="Three tiers. One goal: protect your fleet from theft, sabotage and driver assaults."
  />

  <!-- Pricing tier cards -->
  <WidgetWrapper id="pricing">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 md:grid-cols-3">
        {pricingTiers.map((tier) => (
          <div class={[
            'flex flex-col rounded-2xl border p-8',
            tier.highlighted
              ? 'border-primary border-2 relative'
              : 'border-slate-200 dark:border-slate-700',
          ].join(' ')}>
            {tier.en.badge && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-sm font-semibold text-white">
                {tier.en.badge}
              </span>
            )}
            <h2 class="text-xl font-bold font-heading mb-2">{tier.en.name}</h2>
            <p class="text-3xl font-bold font-heading mb-1">{tier.en.priceDisplay}</p>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">{tier.en.pricePeriod}</p>
            <ul class="flex-1 space-y-3 mb-8">
              {tier.en.features.map((f) => (
                <li class="flex items-start gap-2 text-sm">
                  <span class={f.included ? 'text-green-600 font-bold' : 'text-slate-400'} aria-hidden="true">
                    {f.included ? '✓' : '—'}
                  </span>
                  <span class={f.included ? '' : 'text-slate-400'}>{f.text}</span>
                </li>
              ))}
            </ul>
            <a
              href="#consult-form"
              class="block w-full rounded-lg bg-primary px-6 py-3 text-center text-white font-semibold hover:bg-primary/90 transition-colors"
            >
              {t('cta.book_consult', locale)}
            </a>
          </div>
        ))}
      </div>
    </div>
  </WidgetWrapper>

  <!-- De-minimis teaser (D-04) -->
  <WidgetWrapper>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-lg text-slate-700 dark:text-slate-300">
        Up to 80% funded through the <strong>Government Security &amp; Environment Program</strong> —{' '}
        <a href="/en/funding/" class="text-primary underline underline-offset-2 hover:no-underline">
          learn more →
        </a>
      </p>
    </div>
  </WidgetWrapper>

  <!-- ROI Calculator embed placeholder — wired in Plan 02 -->
  <WidgetWrapper id="roi-calculator">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold font-heading mb-2">How much can you save?</h2>
      <p class="text-slate-600 dark:text-slate-300 mb-6">Calculate your savings potential — including government subsidies.</p>
      <RoiCalculator client:visible locale={locale} embedMode="compact" />
    </div>
  </WidgetWrapper>

  <!-- ConsultForm island -->
  <WidgetWrapper id="consult-form">
    <div class="mx-auto max-w-xl">
      <h2 class="text-2xl font-bold font-heading mb-2 text-center">Book a consult</h2>
      <p class="text-center text-slate-600 dark:text-slate-300 mb-6">Our team will get back to you within 24 hours.</p>
      <ConsultForm client:load locale={locale} />
    </div>
  </WidgetWrapper>

  <!-- Trust section (D-05): testimonial quote -->
  <WidgetWrapper>
    <div class="mx-auto max-w-2xl text-center">
      <blockquote class="text-lg italic text-slate-700 dark:text-slate-300 mb-4">
        "KONVOI fundamentally changed the security of our fleet. No incidents since installation."
      </blockquote>
      <cite class="text-sm text-slate-500">— Schumacher Logistik GmbH</cite>
    </div>
  </WidgetWrapper>

  <CallToAction
    title="Book a consult"
    subtitle="Find out in 20 minutes how KONVOI works for your fleet."
    actions={[{ variant: 'primary', text: 'Book now', href: '#consult-form' }]}
  />
</PageLayout>
