---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { t } from '~/i18n/translations';
import brand from '~/data/brand/canonical.yaml';

const locale = 'en';

const metadata = {
  title: 'KONVOI Product — Sensor-Based Security System for Trailers',
  description:
    'The KONVOI system: GPS, shock and motion sensors, AI classification, and an immediate deterrence chain. Installation in under 120 minutes.',
};
---

<PageLayout metadata={metadata}>

  <Hero
    tagline={t('product.hero_tagline', locale)}
    title={t('product.hero_title', locale)}
    subtitle={t('product.hero_subtitle', locale)}
    videoPoster="/images/hero-poster.jpg"
    actions={[
      {
        variant: 'primary',
        text: t('cta.book_consult', locale),
        href: '#consult',
      },
    ]}
  />

  <Content
    id="hardware"
    tagline={t('product.hardware_tagline', locale)}
    title={t('product.hardware_title', locale)}
    subtitle={t('product.hardware_subtitle', locale)}
    items={[
      {
        title: 'GPS + LTE Connectivity',
        description: 'Real-time tracking and data transmission, even in areas with weak signal coverage.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Shock and Motion Sensors',
        description: 'Detect suspicious patterns — from abnormal door movements to unexpected vibrations.',
        icon: 'tabler:wave-sine',
      },
      {
        title: '7-Day Battery',
        description: 'Self-sufficient. No connection to vehicle electronics required. Operates even when the trailer is uncoupled.',
        icon: 'tabler:battery',
      },
      {
        title: 'Concealed Housing',
        description: 'Compact and discreet mounting. No visible indication of the security system for potential thieves.',
        icon: 'tabler:eye-off',
      },
    ]}
    image={{
      src: '~/assets/images/sensor-positions-placeholder.svg',
      alt: 'Sensor positions on trailer — KONVOI system overview',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    id="how-it-works"
    tagline={t('product.steps_tagline', locale)}
    title={t('product.steps_title', locale)}
    items={[
      {
        title: 'Detection',
        description:
          'Shock, motion, and GPS sensors continuously collect data. Anomalies are registered immediately — e.g. abnormal door movements at 2 am at a motorway rest area.',
        icon: 'tabler:radar',
      },
      {
        title: 'Classification',
        description:
          'The KONVOI AI analyses sensor patterns and classifies the event as a threat or false alarm. No human intervention required — the decision takes seconds.',
        icon: 'tabler:brain',
      },
      {
        title: 'Measures',
        description:
          'Upon confirmed threat, KONVOI immediately triggers the deterrence chain: siren, driver notification, emergency services alert. Theft is prevented, not just documented.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <Features2
    id="add-ons"
    tagline={t('product.addons_tagline', locale)}
    title={t('product.addons_title', locale)}
    subtitle="Extend the KONVOI Standard system as needed."
    columns={2}
    items={[
      {
        title: brand.pricing.tiers[1].en_name,
        description:
          `${brand.pricing.tiers[1].en_description} — A video clip is automatically stored in the cloud on every classified event. Comprehensive evidence for insurance and law enforcement.`,
        icon: 'tabler:video',
      },
      {
        title: brand.pricing.tiers[2].en_name,
        description:
          `${brand.pricing.tiers[2].en_description} — Ideal for compliance requirements and communication with clients. Every journey transparently documented.`,
        icon: 'tabler:file-description',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Content
    id="installation"
    tagline={t('product.install_tagline', locale)}
    title={t('product.install_title', locale)}
    isReversed
    items={[
      {
        title: 'Our own installation team',
        description: 'No third-party contractors. Our team knows the system inside out and guarantees a clean, concealed installation.',
        icon: 'tabler:tool',
      },
      {
        title: brand.install.en_promise,
        description: 'No trailer needs to be out of operation longer than necessary. No dependency on workshop availability.',
        icon: 'tabler:clock',
      },
      {
        title: 'Full service included',
        description: 'Hardware, software, maintenance, and support — all in a single annual contract. No hidden costs.',
        icon: 'tabler:package',
      },
    ]}
    image={{
      src: '~/assets/images/installation-placeholder.svg',
      alt: 'KONVOI installation — under 120 minutes per trailer',
    }}
  />

  <CallToAction
    id="consult"
    title={t('homepage.cta_title', locale)}
    subtitle={t('homepage.cta_subtitle', locale)}
    actions={[
      {
        variant: 'primary',
        text: t('cta.book_consult', locale),
        href: 'mailto:info@konvoi.eu?subject=Product+Enquiry',
      },
    ]}
  />
</PageLayout>
