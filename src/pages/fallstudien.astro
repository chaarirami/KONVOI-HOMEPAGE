---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import CaseStudyCard from '~/components/widgets/CaseStudyCard.astro';
import ConsultCTA from '~/components/widgets/ConsultCTA.astro';

const entries = await getCollection('caseStudy', (e) => e.data.locale === 'de');
const sorted = entries.sort((a, b) =>
  (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
);

const metadata = {
  title: 'Fallstudien — KONVOI GmbH',
  description: 'Erfahren Sie, wie Unternehmen mit KONVOI Cargo-Diebstahl, Diesel-Diebstahl und Trailerschäden präventiv verhindern.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-[hsl(214.48_38.33%_55.49%)]">Kundenerfahrungen</p>
      <h1 class="text-4xl font-bold font-heading text-slate-900 dark:text-white">Fallstudien</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Reale Ergebnisse von Unternehmen, die auf präventive Sicherheit setzen.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((entry) => (
        <CaseStudyCard
          canonicalKey={entry.data.canonicalKey}
          customer={entry.data.customer}
          vertical={entry.data.vertical}
          outcome={entry.data.outcome}
          logo={entry.data.logo}
          coverImage={entry.data.coverImage}
          locale="de"
        />
      ))}
    </div>
  </section>
  <ConsultCTA locale="de" />
</Layout>
