---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Brands from '~/components/widgets/Brands.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { t } from '~/i18n/translations';

const locale = 'de';

const metadata = {
  title: 'KONVOI — Security Tech Made in Germany',
  description:
    'Die erste präventive Sicherheitslösung für Ihre Flotte — gegen Ladungsdiebstahl, Dieselklau, Sabotage und Fahrerangriffe. KONVOI GmbH, Hamburg.',
  ignoreTitleTemplate: true,
};

// Testimonials sourced from current-site-overview.md §6 + §4
// Phase 6 will migrate to caseStudy content collection
const testimonials = [
  {
    name: 'Katrin Sophie Schumacher',
    job: 'Schumacher Group',
    testimonial:
      'Die Installation war in einer Woche abgeschlossen. Seitdem erkennt das System verdächtige Muster sofort — bevor etwas passiert.',
  },
  {
    name: 'JJX Logistics',
    job: 'Hochwertiger Gütertransport',
    testimonial:
      'Mit KONVOI haben wir endlich eine Lösung, die unsere Hochwerttransporte wirklich schützt — nicht nur dokumentiert.',
  },
  {
    name: 'Greilmeier Spedition & Logistik',
    job: 'Spedition',
    testimonial:
      'KONVOI gibt uns die Transparenz, die wir für Compliance und Schadensabwicklung brauchen. Die Schadensdokumentation läuft jetzt automatisch.',
  },
];
---

<PageLayout metadata={metadata}>
  {/* 1. Hero with video background (D-01, D-02, HOME-02) */}
  <Hero
    tagline={t('homepage.hero_tagline', locale)}
    title={t('homepage.hero_title', locale)}
    subtitle={t('homepage.hero_subtitle', locale)}
    videoPoster="/images/hero-poster.jpg"
    actions={[
      {
        variant: 'primary',
        text: t('cta.book_consult', locale),
        href: '#consult',
      },
      {
        variant: 'secondary',
        text: t('cta.learn_more', locale),
        href: '/produkt',
      },
    ]}
  />

  {/* 2. Customer logo wall (D-03, HOME-03) — placeholders until real assets provided */}
  <Brands
    title={t('homepage.logos_title', locale)}
    images={[
      { src: '/images/logos/schumacher.svg', alt: 'Schumacher Group' },
      { src: '/images/logos/jjx.svg', alt: 'JJX Logistics' },
      { src: '/images/logos/greilmeier.svg', alt: 'Greilmeier Spedition & Logistik' },
    ]}
  />

  {/* 3. Testimonials — Schumacher, JJX, Greilmeier (D-03, HOME-04) */}
  <Testimonials
    title={t('homepage.testimonials_title', locale)}
    testimonials={testimonials}
  />

  {/* 4. 3-column value props: Preventive / Learning / Independent (D-03, HOME-05) */}
  <Features
    id="werte"
    title={t('homepage.values_title', locale)}
    columns={3}
    items={[
      {
        title: t('homepage.values_preventive_title', locale),
        description: t('homepage.values_preventive_desc', locale),
        icon: 'tabler:shield-check',
      },
      {
        title: t('homepage.values_learning_title', locale),
        description: t('homepage.values_learning_desc', locale),
        icon: 'tabler:brain',
      },
      {
        title: t('homepage.values_independent_title', locale),
        description: t('homepage.values_independent_desc', locale),
        icon: 'tabler:wifi-off',
      },
    ]}
  />

  {/* 5. Preventive-vs-reactive explainer (D-03) */}
  <Content
    id="praevention"
    tagline={t('homepage.explainer_tagline', locale)}
    title={t('homepage.explainer_title', locale)}
    items={[
      {
        title: 'Klassische GPS-Tracker',
        description:
          'Zeigen, wo der Trailer gestohlen wurde — nach dem Vorfall. Keine Prävention, nur Dokumentation.',
      },
      {
        title: 'KONVOI',
        description:
          'Klassifiziert Bewegungs-, Schock- und GPS-Muster in Echtzeit. Löst eine Abschreckungskette aus, bevor die Ladung den Trailer verlässt.',
      },
    ]}
    image={{
      src: '/images/preventive-vs-reactive.svg',
      alt: 'Prävention vs Reaktion — KONVOI Vergleich',
    }}
    callToAction={{
      text: t('cta.learn_more', locale),
      href: '/produkt',
      variant: 'link',
    }}
  >
    <Fragment slot="content">
      <p class="text-muted">{t('homepage.explainer_body', locale)}</p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  {/* 6. Press mentions strip (D-03, HOME-06) — placeholders */}
  <Brands
    title={t('homepage.press_title', locale)}
    images={[
      { src: '/images/logos/press-placeholder-1.svg', alt: 'Presserwähnung 1' },
      { src: '/images/logos/press-placeholder-2.svg', alt: 'Presserwähnung 2' },
      { src: '/images/logos/press-placeholder-3.svg', alt: 'Presserwähnung 3' },
    ]}
  />

  {/* 7. Partners / investors strip (D-03, HOME-07) — placeholders */}
  <Brands
    title={t('homepage.partners_title', locale)}
    images={[
      { src: '/images/logos/startup-port.svg', alt: 'Startup Port' },
      { src: '/images/logos/1750-ventures.svg', alt: '1750 Ventures' },
      { src: '/images/logos/vgh.svg', alt: 'VGH Versicherungen' },
    ]}
  />

  {/* 8. End-of-page consult CTA (D-03, HOME-08) */}
  <CallToAction
    id="consult"
    title={t('homepage.cta_title', locale)}
    subtitle={t('homepage.cta_subtitle', locale)}
    actions={[
      {
        variant: 'primary',
        text: t('cta.book_consult', locale),
        href: 'mailto:info@konvoi.eu?subject=Beratungsanfrage',
      },
    ]}
  />
</PageLayout>
