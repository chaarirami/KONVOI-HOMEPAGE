---
import Layout from '~/layouts/PageLayout.astro';
import HeroVideo from '~/components/widgets/HeroVideo.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CustomerMarquee from '~/components/widgets/CustomerMarquee.astro';
import LogoGrid from '~/components/widgets/LogoGrid.astro';
import FleetGlobe from '~/components/widgets/FleetGlobe.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ConsultForm from '~/components/islands/ConsultForm';
import { pressLogos } from '~/data/press';
import { supporters } from '~/data/supporters';
import { t } from '~/i18n/translations';
import { getCollection } from 'astro:content';

const locale = 'de' as const;
const calUrl = import.meta.env.PUBLIC_CAL_BOOKING_URL;

const caseStudiesDe = await getCollection('caseStudy', ({ data }) =>
  data.locale === 'de' && ['schumacher', 'jjx', 'greilmeier'].includes(data.canonicalKey)
);

const testimonials = caseStudiesDe.map((cs) => ({
  testimonial: cs.data.quote ?? '',
  name: cs.data.quoteAttribution ?? cs.data.customer,
  job: cs.data.vertical,
}));

const metadata = {
  title: 'KONVOI — Security Tech Made in Germany',
  description:
    'Die erste präventive Lösung für Ihre Flotte — gegen Ladungsdiebstahl, Dieselklau, Sabotage und Fahrerangriffe. Sensor-basiertes Security-as-a-Service für Trailer.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Section 1: Hero with background video (D-04, HOME-02) -->
  <HeroVideo
    tagline="Security Tech Made in Germany"
    title="Die erste präventive Lösung für Ihre Flotte"
    subtitle="KONVOI schützt Ihren Trailer gegen Ladungsdiebstahl, Dieselklau, Sabotage und Fahrerangriffe — bevor sie passieren."
    videoSrc="/videos/hero-bg.mp4"
    posterImage="/images/placeholders/hero-bg.jpg"
    actions={[
      { variant: 'primary', text: 'Beratung anfragen', href: '#consult' },
      { variant: 'secondary', text: 'Mehr erfahren', href: '/produkt' },
    ]}
  />

  <CustomerMarquee title="Bereits im Einsatz bei führenden Logistikanbietern" />

  <FleetGlobe
    tagline="Live-Tracking"
    title="Ihre Flotte. In Echtzeit geschützt."
    subtitle="KONVOI Sensorsysteme im aktiven Einsatz — rund um die Uhr."
  />

  <!-- Section 2: Preventive-vs-reactive explainer (HOME-05, D-05) -->
  <Features2
    tagline="Prävention statt Reaktion"
    title="Warum präventiv besser ist"
    subtitle="Klassische GPS-Tracker zeigen Ihnen nur, wo der Trailer gestohlen wurde — nach dem Vorfall. KONVOI klassifiziert Bewegungs-, Schock- und GPS-Muster in Echtzeit und löst eine Abschreckungskette aus, bevor die Ladung den Trailer verlässt."
    columns={3}
    items={[
      {
        title: 'Präventiv',
        description:
          'Erkennt und klassifiziert Bedrohungsmuster, bevor Schaden entsteht. Kein reaktives Nachverfolgen — aktives Verhindern.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Lernend',
        description:
          'Künstliche Intelligenz verbessert die Klassifizierung mit jedem Ereignis in Ihrer Flotte. Weniger Fehlalarme, mehr Sicherheit.',
        icon: 'tabler:brain',
      },
      {
        title: 'Unabhängig',
        description:
          '7-Tage-Akku. Funktioniert vollständig offline. Keine externe Infrastruktur oder permanente Netzwerkverbindung erforderlich.',
        icon: 'tabler:battery-eco',
      },
    ]}
  />

  <!-- Section 3: Use-case teaser cards (HOME-05, D-06) -->
  <Features2
    tagline="Anwendungen"
    title="Schutz gegen alle Bedrohungstypen"
    subtitle="KONVOI deckt die sieben häufigsten Sicherheitsrisiken im Trailer-Transport ab — von Ladungsdiebstahl bis zur Standzeit-Optimierung."
    columns={4}
    items={[
      {
        title: 'Ladungsdiebstahl',
        description:
          '€8 Mrd. Schaden jährlich in Europa. KONVOI verhindert Diebstahl, bevor er passiert.',
        icon: 'tabler:box-off',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/ladungsdiebstahl', variant: 'link' },
      },
      {
        title: 'Dieseldiebstahl',
        description:
          'Bis zu €2.000 pro Vorfall. KONVOI erkennt und verhindert Kraftstoffdiebstahl am Trailer.',
        icon: 'tabler:droplet-off',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/dieseldiebstahl', variant: 'link' },
      },
      {
        title: 'Equipmentdiebstahl',
        description:
          '€600 pro Reifen, €3.600 pro Trailer. Sensor-Überwachung schützt Ihre Ausrüstung.',
        icon: 'tabler:tools-off',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/equipmentdiebstahl', variant: 'link' },
      },
      {
        title: 'Transparenz der Operationen',
        description:
          'Lückenlose Dokumentation aller Kopplungsvorgänge — für Compliance und Haftungsschutz.',
        icon: 'tabler:eye-check',
        callToAction: {
          text: 'Mehr erfahren',
          href: '/anwendungen/transparenz-der-operationen',
          variant: 'link',
        },
      },
      {
        title: 'Trailerschäden',
        description:
          'Schocksensor-Daten rekonstruieren Schadensereignisse für Versicherung und Compliance.',
        icon: 'tabler:alert-triangle',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/trailerschaeden', variant: 'link' },
      },
      {
        title: 'Fahrerangriffe',
        description:
          'Präventive Abschreckung und sofortige Alarmkette schützen Ihr Fahrpersonal.',
        icon: 'tabler:user-shield',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/fahrerangriffe', variant: 'link' },
      },
      {
        title: 'Standzeit-Optimierung',
        description:
          'Echtzeit-Standzeit-Daten reduzieren ungeplante Haltezeiten und verbessern Flottenauslastung.',
        icon: 'tabler:clock-check',
        callToAction: { text: 'Mehr erfahren', href: '/anwendungen/standzeit-optimierung', variant: 'link' },
      },
    ]}
  />

  <!-- Section 4: Testimonials sourced from caseStudy collection (HOME-04) -->
  {testimonials.length > 0 && (
    <Testimonials
      title="Das sagen unsere Kunden"
      subtitle="Reale Ergebnisse von Unternehmen, die auf präventive Sicherheit setzen."
      testimonials={testimonials}
    />
  )}

  <LogoGrid title="Bekannt aus" logos={pressLogos} />

  <LogoGrid title="Unterstützt von" logos={supporters} />

  <!-- Section 8: Consult form + Cal.eu booking (HOME-08) -->
  <WidgetWrapper id="consult">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold font-heading mb-2">Sicherheit für Ihre Flotte</h2>
        <p class="text-slate-600 dark:text-slate-300">
          Erfahren Sie in 20 Minuten, wie KONVOI für Ihr Unternehmen funktioniert. Kostenlose Erstberatung — unverbindlich.
        </p>
      </div>
      <div class={`grid gap-8 ${calUrl ? 'md:grid-cols-2' : ''} items-start`}>
        <div>
          <ConsultForm client:load locale={locale} />
        </div>
        {calUrl && (
          <div class="flex flex-col items-center justify-center rounded-2xl border border-slate-200 dark:border-slate-700 p-8 text-center">
            <h3 class="text-xl font-bold font-heading mb-2">
              {t('thanks.cal_heading', locale)}
            </h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6">
              {t('thanks.cal_body', locale)}
            </p>
            <a
              href={calUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-lg bg-primary px-6 py-3 text-white font-semibold hover:bg-primary/90 transition-colors"
            >
              {t('thanks.cal_cta', locale)}
            </a>
          </div>
        )}
      </div>
    </div>
  </WidgetWrapper>
</Layout>
