---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import ConsultCTA from '~/components/widgets/ConsultCTA.astro';
import { t } from '~/i18n/translations';
import PricingCalculator from '~/components/islands/PricingCalculator';
import RoiCalculator from '~/components/islands/RoiCalculator';

const locale = 'de' as const;

const metadata = {
  title: 'Preise — KONVOI Security System',
  description: 'Transparente Preise für das KONVOI Sicherheitssystem. Drei Stufen: Standard, Camera Module, Logbook. Bis zu 80% staatlich förderbar.',
};
---

<PageLayout metadata={metadata}>
  <Hero
    tagline="Preise"
    title="Investition in Sicherheit — mit bis zu 80% staatlicher Förderung"
    subtitle="Vier Pakete — skalierbar nach Ihren Anforderungen."
  />

  <!-- Dynamic Pricing Calculator -->
  <WidgetWrapper id="preise">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <PricingCalculator client:visible locale={locale} />
    </div>
  </WidgetWrapper>

  <!-- De-minimis teaser (D-04) -->
  <WidgetWrapper>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-lg text-slate-700 dark:text-slate-300">
        Bis zu 80% förderbar durch das <strong>Förderprogramm Umweltschutz und Sicherheit</strong> —{' '}
        <a href="/foerderung/" class="text-primary underline underline-offset-2 hover:no-underline">
          mehr erfahren →
        </a>
      </p>
    </div>
  </WidgetWrapper>

  <!-- ROI Calculator embed placeholder — wired in Plan 02 -->
  <WidgetWrapper id="roi-calculator">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold font-heading mb-2">Wie viel können Sie sparen?</h2>
      <p class="text-slate-600 dark:text-slate-300 mb-6">Berechnen Sie Ihr Einsparpotenzial — inklusive staatlicher Förderung.</p>
      <RoiCalculator client:visible locale={locale} embedMode="compact" />
    </div>
  </WidgetWrapper>

  <!-- Trust section (D-05): Schumacher testimonial quote -->
  <WidgetWrapper>
    <div class="mx-auto max-w-2xl text-center">
      <blockquote class="text-lg italic text-slate-700 dark:text-slate-300 mb-4">
        "KONVOI hat die Sicherheit unserer Flotte grundlegend verändert. Kein Vorfall seit der Installation."
      </blockquote>
      <cite class="text-sm text-slate-500">— Schumacher Logistik GmbH</cite>
    </div>
  </WidgetWrapper>

  <ConsultCTA locale={locale} id="consult-form" />
</PageLayout>
