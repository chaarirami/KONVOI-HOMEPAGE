---
import fs from 'node:fs';
import yaml from 'js-yaml';

const configText = fs.readFileSync('public/decap-config.yml', 'utf-8');
const cmsConfig = yaml.load(configText) as Record<string, unknown>;
if (import.meta.env.DEV) {
  cmsConfig.local_backend = true;
}
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Content Manager | KONVOI</title>
  </head>
  <body>
    <script is:inline define:vars={{ cmsConfig }}>
      window.CMS_MANUAL_INIT = true;
      window.__cmsConfig = cmsConfig;
    </script>
    <script is:inline src="https://unpkg.com/decap-cms@^3.3/dist/decap-cms.js"></script>
    <script is:inline>
      window.CMS.init({ config: window.__cmsConfig });
    </script>
  </body>
</html>
