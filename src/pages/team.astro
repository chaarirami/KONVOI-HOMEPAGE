---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import TeamGrid from '~/components/widgets/TeamGrid.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const members = await getCollection('team');

const metadata = {
  title: 'Team — KONVOI GmbH',
  description: 'Das Team hinter KONVOI: neun Experten aus Hardware, KI, Logistik und Sales, die präventive Flottensicherheit neu definieren.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-[hsl(214.48_38.33%_55.49%)]">
        Das Team
      </p>
      <h1 class="text-4xl font-bold font-heading text-slate-900 dark:text-white">Unser Team</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Gegründet 2020 als Spin-off der Technischen Universität Hamburg. Neun Expertinnen und Experten, die präventive Sicherheit für die Logistikbranche entwickeln.
      </p>
    </div>
    <TeamGrid members={members} locale="de" />
  </section>
  <CallToAction
    title="Lernen Sie uns kennen"
    subtitle="Vereinbaren Sie ein Beratungsgespräch und sprechen Sie direkt mit unserem Team."
    actions={[{ variant: 'primary', text: 'Beratung anfragen', href: '/kontakt' }]}
  />
</Layout>
