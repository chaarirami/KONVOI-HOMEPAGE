---
// src/pages/roi.astro — DE standalone ROI calculator page
import PageLayout from '~/layouts/PageLayout.astro';
import RoiCalculator from '~/components/islands/RoiCalculator';
import { t } from '~/i18n/translations';

const locale = 'de';
const metadata = {
  title: 'ROI-Rechner — KONVOI GmbH',
  description: 'Berechnen Sie Ihren Return on Investment mit KONVOI.',
};
---
<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-16 text-center">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-konvoi-primary">
      {t('roi.hero_tagline', locale)}
    </p>
    <h1 class="font-heading text-4xl font-bold text-slate-900 dark:text-white">
      {t('roi.hero_title', locale)}
    </h1>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
      {t('roi.hero_subtitle', locale)}
    </p>
  </section>
  <div class="mx-auto max-w-3xl px-4 pb-20">
    <RoiCalculator locale={locale} client:visible />
  </div>
</PageLayout>
