---
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import RoiCalculator from '~/components/islands/RoiCalculator';
import { t } from '~/i18n/translations';

const locale = 'de' as const;

const metadata = {
  title: 'ROI Rechner — KONVOI Security System',
  description:
    'Berechnen Sie Ihr Einsparpotenzial mit KONVOI — inklusive 80% staatlicher Förderung durch das Förderprogramm Umweltschutz und Sicherheit.',
};
---

<PageLayout metadata={metadata}>
  <Hero
    tagline={t('roi.page_tagline', locale)}
    title={t('roi.page_title', locale)}
    subtitle={t('roi.page_subtitle', locale)}
  />

  <WidgetWrapper id="roi-calculator">
    <div class="mx-auto max-w-2xl">
      <RoiCalculator client:load locale={locale} embedMode="full" />
    </div>
  </WidgetWrapper>

  <CallToAction
    title="Bereit für den nächsten Schritt?"
    subtitle="Unser Team erklärt Ihnen in 20 Minuten, wie KONVOI Ihre Flotte schützt."
    actions={[{ text: t('cta.book_consult', locale), href: '/preise/#consult-form', variant: 'primary' }]}
  />
</PageLayout>
