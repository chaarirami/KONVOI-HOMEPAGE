---
import type { PaginateFunction } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Grid from '~/components/blog/Grid.astro';
import Pagination from '~/components/blog/Pagination.astro';

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const posts = await getCollection('post', (e) => e.data.locale === 'de' && !e.data.draft);
  const sorted = posts.sort(
    (a, b) => (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
  );
  return paginate(sorted, { pageSize: 6 });
}

const { page } = Astro.props;
const metadata = {
  title: 'Aktuelles — KONVOI GmbH',
  description: 'Neuigkeiten, Analysen und Einblicke von KONVOI — dem Sicherheitstechnologieunternehmen für die Logistikbranche.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold font-heading text-slate-900 dark:text-white">Aktuelles</h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">Neuigkeiten und Analysen von KONVOI.</p>
      <a href="/aktuelles/rss.xml" class="mt-2 inline-flex items-center gap-1 text-sm text-[hsl(214.48_38.33%_55.49%)] hover:underline">
        RSS Feed
      </a>
    </div>
    {page.data.length === 0 && (
      <p class="text-center text-slate-500 py-16">Keine Beiträge gefunden.</p>
    )}
    {page.data.length > 0 && (
      <Grid posts={page.data.map((e) => ({
        id: e.id,
        slug: e.data.canonicalKey,
        permalink: `/aktuelles/${e.data.canonicalKey}/`,
        title: e.data.title,
        excerpt: e.data.excerpt,
        image: e.data.image,
        publishDate: e.data.publishDate ?? new Date(),
        author: e.data.author,
        tags: e.data.tags?.map((t) => ({ slug: t.toLowerCase().replace(/\s+/g, '-'), title: t })),
        category: e.data.category ? { slug: e.data.category.toLowerCase().replace(/\s+/g, '-'), title: e.data.category } : undefined,
        metadata: e.data.metadata,
      }))} />
    )}
    <div class="mt-8">
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </section>
</Layout>
