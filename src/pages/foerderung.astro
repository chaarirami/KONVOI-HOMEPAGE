---
// src/pages/foerderung.astro — DE funding page
// Per D-15: /foerderung/ explains 80% de-minimis subsidy citing catalog section 1.10.
// Per D-16: embeds FundingQualifierForm island.
// Per D-17: content structure: what-is → eligibility → how KONVOI qualifies → ROI link → form.
// Per FUND-04 / D-16: cross-link to /roi for combined savings-plus-subsidy figure.

import PageLayout from '~/layouts/PageLayout.astro';
import FundingQualifierForm from '~/components/islands/FundingQualifierForm';
import { t } from '~/i18n/translations';
import brand from '~/data/brand/canonical.yaml';

const locale = 'de';
const metadata = {
  title: 'Förderung — KONVOI GmbH',
  description: `Bis zu ${brand.funding.de_minimis_max_percent}% Förderung durch die Berufsgenossenschaft. KONVOI qualifiziert sich für BG-Katalog Abschnitt ${brand.funding.de_catalog_section}.`,
};
---
<PageLayout metadata={metadata}>
  <!-- Turnstile script — explicit render required per D-11 / RESEARCH.md Pattern 2 -->
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
  ></script>

  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-4 py-16 text-center">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-konvoi-primary">
      {t('funding.hero_tagline', locale)}
    </p>
    <h1 class="text-4xl font-bold font-heading text-slate-900 dark:text-white">
      {t('funding.hero_title', locale)}
    </h1>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
      {t('funding.hero_subtitle', locale)}
    </p>
    <!-- Catalog badge — cites section 1.10 per FUND-02 -->
    <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 dark:border-blue-800 dark:bg-blue-950 dark:text-blue-300">
      <span>BG-Katalog §{brand.funding.de_catalog_section}</span>
      <span class="text-blue-400">·</span>
      <span>{brand.funding.de_catalog_ref}</span>
    </div>
  </section>

  <!-- Content: D-17 structure -->
  <div class="mx-auto max-w-3xl px-4 pb-12 space-y-12">

    <!-- 1. What is de-minimis -->
    <section>
      <h2 class="text-2xl font-bold font-heading text-slate-900 dark:text-white mb-3">
        {t('funding.section_what_title', locale)}
      </h2>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
        {t('funding.section_what_body', locale)}
      </p>
    </section>

    <!-- 2. Eligibility -->
    <section>
      <h2 class="text-2xl font-bold font-heading text-slate-900 dark:text-white mb-3">
        {t('funding.section_eligibility_title', locale)}
      </h2>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
        {t('funding.section_eligibility_body', locale)}
      </p>
    </section>

    <!-- 3. How KONVOI qualifies -->
    <section>
      <h2 class="text-2xl font-bold font-heading text-slate-900 dark:text-white mb-3">
        {t('funding.section_konvoi_title', locale)}
      </h2>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
        {t('funding.section_konvoi_body', locale)}
      </p>
    </section>

    <!-- 4. Cross-link to ROI calculator (FUND-04 / D-16) -->
    <section class="rounded-2xl border border-konvoi-primary/20 bg-konvoi-primary/5 p-6">
      <p class="text-slate-700 dark:text-slate-200 mb-3">
        {`Berechnen Sie Ihre kombinierten Einsparungen — KONVOI-Einsparung plus ${brand.funding.de_minimis_max_percent}% De-minimis-Rückerstattung.`}
      </p>
      <a
        href="/roi"
        class="inline-flex items-center gap-1 font-semibold text-konvoi-primary hover:underline"
      >
        {t('funding.section_roi_link', locale)} →
      </a>
    </section>

  </div>

  <!-- 5. FundingQualifierForm (D-16, FUND-03) -->
  <section id="qualify" class="mx-auto max-w-2xl px-4 py-16">
    <div class="mb-6 text-center">
      <h2 class="text-3xl font-bold font-heading text-slate-900 dark:text-white">
        {t('funding.qualifier_title', locale)}
      </h2>
      <p class="mt-2 text-slate-500 dark:text-slate-400">
        {t('funding.qualifier_subtitle', locale)}
      </p>
    </div>
    <!-- FundingQualifierForm built in Task 1. client:visible per D-08. -->
    <FundingQualifierForm locale={locale} client:visible />
  </section>
</PageLayout>
